{
  "name": "readwillbe",
  "version": "0.1.0",
  "description": "Reading planner and tracker",
  "private": true,
  "scripts": {
    "init": "tailwindcss -i ./input.css -o ./static/css/main.css",
    "dev": "tailwindcss -i ./input.css -o ./static/css/main.css --watch",
    "build": "tailwindcss -i ./input.css -o ./static/css/main.css --minify",
    "build:js": "node tools/build.js",
    "watch:js": "node tools/build.js --watch",
    "watch:css": "node tools/watch_css.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:js": "eslint assets/js"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tanstack/react-query": "^5.80.6",
    "react-hook-form": "^7.56.4",
    "lucide-react": "^1.0.0",
    "date-fns": "^4.1.0",
    "react-day-picker": "^10.0.0"
  },
  "devDependencies": {
    "@parcel/watcher": "2.5.6",
    "@tailwindcss/oxide": "4.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "daisyui": "5.5.23",
    "esbuild": "0.28.0",
    "lightningcss": "1.32.0",
    "prettier": "3.4.2",
    "typescript": "6.0.3",
    "zod": "4.4.3",
    "@hookform/resolvers": "5.4.0",
    "eslint": "10.4.1",
    "@eslint/js": "10.0.1",
    "typescript-eslint": "8.60.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6"
  }
}
